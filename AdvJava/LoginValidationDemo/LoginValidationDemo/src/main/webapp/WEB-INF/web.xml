<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="https://jakarta.ee/xml/ns/jakartaee"
	xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
	id="WebApp_ID" version="6.0">
	
	
	
	<display-name>LoginValidationDemo</display-name>


	<context-param>
		<param-name>driver</param-name>
		<param-value> com.mysql.cj.jdbc.Driver</param-value>
	</context-param>


	<context-param>
		<param-name>url</param-name>
		
		<param-value> jdbc:mysql://localhost:3306/jdbcpractic</param-value>
	</context-param>

	<context-param>
		<param-name>username</param-name>
		<param-value>root</param-value>
	</context-param>

	<context-param>
		<param-name>password</param-name>
		<param-value>Shankar@5858</param-value>
	</context-param>





	<servlet>
		<servlet-name>authentication</servlet-name>
		<servlet-class>com.demo.LoginServlet</servlet-class>
		<init-param>

			<param-name>companyname</param-name>
			<param-value>tcs.com</param-value>
		</init-param>
	</servlet>
	<servlet-mapping>
		<servlet-name>authentication</servlet-name>
		<url-pattern>/login</url-pattern>
	</servlet-mapping>
	
	
	<servlet>
		<servlet-name>Databsemanagement</servlet-name>
		<servlet-class>com.demo.DatabaseManagement</servlet-class>
		
	</servlet>
	<servlet-mapping>
		<servlet-name>Databsemanagement</servlet-name>
		<url-pattern>/data</url-pattern>
	</servlet-mapping>

<servlet>
    <servlet-name>PaymentServlet</servlet-name>
    <servlet-class>com.demo.paymentservilate</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>PaymentServlet</servlet-name>
    <url-pattern>/payment</url-pattern>
</servlet-mapping>


</web-app>